# --- Entorno virtual ---
supervision/
venv/
.venv/
__pycache__/
*.pyc
*.pyo

# --- Videos (demasiado grandes para git) ---
*.mp4
*.avi
*.mov
*.mkv

# --- Pesos de modelos YOLO (>5 MB) ---
models/*.pt
models/*.pth
models/*.weights
