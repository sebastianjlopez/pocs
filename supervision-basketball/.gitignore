!models/.gitkeep

# --- Outputs generados ---
outputs/*.json
outputs/*.csv
outputs/*.mp4
outputs/*.avi
outputs/*.txt
# Excepción: permitir el .gitkeep
!outputs/.gitkeep

# --- Archivos de debug ---
*.jpg
*.png
debug_*
test_frame*

